{
  "agent": {
    "metrics_collection_interval": 60,
    "run_as_user": "root"
  },
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/sentinel-app/app.log",
            "log_group_name": "/sentinel/app",
            "log_stream_name": "{instance_id}/app.log",
            "retention_in_days": 7
          },
          {
            "file_path": "/var/log/cloud-init-output.log",
            "log_group_name": "/sentinel/system",
            "log_stream_name": "{instance_id}/cloud-init-output.log",
            "retention_in_days": 7
          }
        ]
      }
    }
  },
  "metrics": {
    "namespace": "Sentinel",
    "append_dimensions": {
      "InstanceId": "${aws:InstanceId}"
    },
    "metrics_collected": {
      "disk": {
        "measurement": ["used_percent", "free", "used"],
        "resources": ["/"],
        "metrics_collection_interval": 60,
        "drop_device": true
      },
      "mem": {
        "measurement": ["mem_used_percent", "mem_available", "mem_used"],
        "metrics_collection_interval": 60
      },
      "cpu": {
        "measurement": ["cpu_usage_active", "cpu_usage_idle"],
        "metrics_collection_interval": 60,
        "totalcpu": true
      }
    }
  }
}